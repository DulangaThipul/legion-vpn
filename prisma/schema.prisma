generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id               String    @id @default(auto()) @map("_id") @db.ObjectId
  email            String    @unique
  name             String
  image            String?
  googleImage      String?
}
  
  // VPN Details
  vpnStatus        String    @default("Inactive") // "Active" or "Inactive"
  expiryDate       DateTime?
  vpnConfigKey     String?
  subscriptionLink String?

  reviews          Review[]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model Review {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])
  rating    Int
  text      String
  createdAt DateTime @default(now())
}
